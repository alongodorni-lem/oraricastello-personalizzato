# Planyo (stesse credenziali del backend prenotazioni)
PLANYO_API_KEY=
PLANYO_SITE_ID=8895

# Lista D da CSV: URL report Planyo (es. show-admin-report.php?calendar=...&download=default&shsec=...)
# Se impostato, Lista D viene caricata dal CSV invece che dall'API. Il token shsec può scadere.
# PLANYO_LISTD_CSV_URL=

# Mesi lookback Planyo (default 18). Imposta 12 per preview più veloce se timeout su Render
# PLANYO_MONTHS_LOOKBACK=12

# Mailchimp - API key con datacenter (es. xxxxxxxx-us21)
MAILCHIMP_API_KEY=
MAILCHIMP_CAMPAIGN_ID=

# Smshosting - da area riservata > Gestione sicurezza API
SMSHOSTING_AUTH_KEY=
SMSHOSTING_AUTH_SECRET=
# Mittente alfanumerico (max 11 caratteri) - es. grottanatal
# SMSHOSTING_USE_ALIAS=true per usarlo, altrimenti mittente numerico
# SMSHOSTING_FROM=
# SMSHOSTING_USE_ALIAS=

# Gmail - per Newsletter EMAIL (invio email personalizzate)
# Crea una App Password da account Google: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Sicurezza interfaccia web: se impostati, richiede login (Basic Auth)
# NEWSLETTER_SMS_USER=
# NEWSLETTER_SMS_PASSWORD=

# Opzionale: da riga di comando
# node index.js --campaign=abc123     # singola campagna
# node index.js --last=2               # ultime 2 campagne inviate
